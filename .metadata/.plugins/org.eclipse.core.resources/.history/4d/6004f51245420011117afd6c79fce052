
public class Vowelspresent {

	public static void main(String[] args) {
	String s = "Learningo";
	//How many vowel characters present in the given string
	
	String vowels = "aeiou";
	int count = 0;
	
	for (char c: s.toCharArray()) {
		if (vowels.contains(String.valueOf(c))) {
			 	count ++;
		}
	}
	System.out.println(count);

	}

}
