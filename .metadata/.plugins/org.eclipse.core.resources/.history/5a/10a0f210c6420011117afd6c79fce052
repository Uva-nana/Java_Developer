
public class Stringrotation {

	public static void main(String[] args) {

		 String s1 = "abcde";                                                                                                                             
         String s2 = "decba";

         if (s1.length() == s2.length() && (s1 + s1).contains(s2)) {
             System.out.println("Rotation");
         } else {
             System.out.println("Not Rotation");

	}

}
